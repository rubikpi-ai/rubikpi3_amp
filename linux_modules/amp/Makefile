obj-m += amp.o
KDIR ?= /lib/modules/$(shell uname -r)/build
CROSS_COMPILE := aarch64-linux-gnu-
ARCH := arm64

# Build output directory (passed from parent Makefile)
BUILD_DIR ?= $(CURDIR)/../../build/linux_modules/amp

# Intermediate files generated by kbuild
KBUILD_INTERMEDIATES := *.ko *.o *.mod *.mod.o *.mod.c .*.cmd .*.o .*.ko \
                        .tmp_versions Module.symvers modules.order .module-common.o

all: $(BUILD_DIR)
	@if [ ! -f "$(KDIR)/Makefile" ]; then \
		echo "error: Linux kernel build tree not found: $(KDIR)" >&2; \
		echo "hint: invoke with 'make KDIR=/path/to/linux' or top-level 'make modules LINUX_KDIR=/path/to/linux'" >&2; \
		exit 1; \
	fi
	$(MAKE) ARCH=$(ARCH) CROSS_COMPILE=$(CROSS_COMPILE) -C $(KDIR) M=$(CURDIR) modules
	@cp -f $(CURDIR)/amp.ko $(BUILD_DIR)/
	@echo "  Copied amp.ko to $(BUILD_DIR)/"
	@# Clean intermediate files from source directory
	@rm -f $(CURDIR)/*.o $(CURDIR)/*.mod $(CURDIR)/*.mod.c $(CURDIR)/*.mod.o
	@rm -f $(CURDIR)/.*.cmd $(CURDIR)/.*.o $(CURDIR)/.*.ko
	@rm -f $(CURDIR)/*.ko $(CURDIR)/Module.symvers $(CURDIR)/modules.order
	@rm -f $(CURDIR)/.module-common.o
	@rm -rf $(CURDIR)/.tmp_versions

$(BUILD_DIR):
	@mkdir -p $(BUILD_DIR)

clean:
	rm -f $(KBUILD_INTERMEDIATES)
	rm -rf .tmp_versions
	rm -rf $(BUILD_DIR)
